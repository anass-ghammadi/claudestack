---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.3.e — wraps demo article pages with banner
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import DemoBanner from '../components/DemoBanner.astro';
import CodeBlock from '../components/CodeBlock.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../lib/format-date';
import { readingTime } from '../lib/reading-time';

interface Props {
  article: CollectionEntry<'demo-articles'>;
  rawBody: string;
  headings: MarkdownHeading[];
}

const { article, rawBody, headings } = Astro.props;
const { title, description, pubDate, author, tags } = article.data;
const time = readingTime(rawBody);
---

<BaseLayout title={title} description={description} noindex>
  <article class="article">
    <div class="container">
      <div class="article-inner">
        <DemoBanner />

        <div class="article-meta-top">
          <span>{formatDate(pubDate)}</span>
          <span>by {author}</span>
          {tags.slice(0, 3).map((tag) => (
            <a href={`/demo`}>#{tag}</a>
          ))}
        </div>

        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>

        <div class="article-meta-bottom">
          <span>{time.label}</span>
          <span>{time.words.toLocaleString()} words</span>
        </div>

        <TableOfContents headings={headings} />

        <div class="prose">
          <slot />
        </div>
      </div>
    </div>
  </article>

  <CodeBlock />
</BaseLayout>
