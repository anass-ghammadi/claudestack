---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleList from '../../components/ArticleList.astro';
import SearchBox from '../../components/SearchBox.astro';

const articles = (await getCollection('articles', (e) => !e.data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="archive" description="Every field report from ClaudeStack — essays, patterns, and guides on building production systems with Claude Code.">
  <section class="articles-section">
    <div class="container">
      <div class="section-head">
        <div class="section-head-left">
          <div class="section-head-meta">FULL_INDEX · {articles.length} REPORTS</div>
          <h2>The <span class="accent">archive</span></h2>
        </div>
        <div class="section-head-filters">
          <a class="filter-pill active" href="/articles">all</a>
          <a class="filter-pill" href="/categories/essays">essays</a>
          <a class="filter-pill" href="/categories/patterns">patterns</a>
          <a class="filter-pill" href="/categories/guides">guides</a>
        </div>
      </div>

      <SearchBox />
      <ArticleList articles={articles} />
    </div>
  </section>
</BaseLayout>
