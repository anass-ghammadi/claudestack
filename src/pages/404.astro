---
// SPEC: BRIEF_ADDENDUM_LAUNCH_READY.md#4 — branded 404, on-theme, links back to key pages
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — page not found" description="The page you requested doesn't exist on this filesystem." noindex>
  <section class="notfound">
    <div class="container">
      <div class="notfound-inner">
        <div class="notfound-status">cd {Astro.url.pathname} → No such file or directory</div>
        <h1><span class="accent">ERROR</span> 404</h1>
        <p class="notfound-msg">
          <span class="comment"># the page you requested was not found in this filesystem.</span><br />
          <br />
          either the URL is wrong, or the page has been moved, or it<br />
          never existed in the first place. logs are inconclusive.
        </p>

        <div class="notfound-suggestions">
          <div class="notfound-suggestions-head">suggestions.txt</div>
          <a href="/">return to home</a>
          <a href="/blog">browse the blog</a>
          <a href="/demo">try the template demo</a>
          <a href="/pricing">see pricing</a>
          <a href="/about">about this site</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
