---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — about copy from siteConfig.about
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const a = siteConfig.about;
---

<BaseLayout
  title="About"
  description={`${siteConfig.name} — ${siteConfig.author.bio}`}
>
  <section class="page-section">
    <div class="container">
      <div class="page-inner">
        <div class="page-meta">{a.metaTag}</div>
        <h1 class="page-title">{a.headline} <span class="accent">{a.headlineAccent}</span>.</h1>

        <div class="prose">
          {a.body.map((p) => <p>{p}</p>)}

          {a.sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              {section.intro && <p>{section.intro}</p>}
              <ul>
                {section.bullets.map((bullet) => (
                  <li set:html={bullet.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}></li>
                ))}
              </ul>
            </>
          ))}

          <h2>Author</h2>
          <p>{siteConfig.author.bio}</p>
          <p>
            Find me on <a href={siteConfig.author.github} rel="noopener">GitHub</a>
            {siteConfig.author.email && (
              <>, or <a href={`mailto:${siteConfig.author.email}`}>email me</a></>
            )}.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
