---
import type { CollectionEntry } from 'astro:content';
import CategoryBadge from './CategoryBadge.astro';
import { formatDate } from '../lib/format-date';
import { readingTime } from '../lib/reading-time';

interface Props {
  article: CollectionEntry<'blog'>;
  num: number;
}

const { article, num } = Astro.props;
const { title, description, pubDate, category } = article.data;
const time = readingTime(article.body ?? '');
const numLabel = `№ ${String(num).padStart(3, '0')}`;
---

<a class="article-row" href={`/blog/${article.id}`}>
  <div class="article-row-header">
    <div class="article-num">{numLabel}</div>
    <CategoryBadge category={category} />
  </div>
  <div class="article-title">
    <h3>{title}</h3>
    <p>// {description}</p>
  </div>
  <div class="article-row-footer">
    <div class="article-row-footer-left">
      <span class="article-date">{formatDate(pubDate)}</span>
      <span class="article-time">{time.label}</span>
    </div>
    <span class="article-arrow">→</span>
  </div>
</a>
