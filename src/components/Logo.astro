---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — reads brand name from siteConfig
import { siteConfig } from '../config/site';

interface Props {
  variant?: 'nav' | 'footer';
  href?: string;
}

const { variant = 'nav', href = '/' } = Astro.props;
const className = variant === 'footer' ? 'footer-logo' : 'logo';
const label = siteConfig.name.toLowerCase();
---

{
  variant === 'footer' ? (
    <div class={className}>
      <span class="logo-bracket">[</span>{label}<span class="logo-bracket">]</span>
    </div>
  ) : (
    <a href={href} class={className} aria-label={siteConfig.name}>
      <span class="logo-bracket">[</span>{label}<span class="logo-bracket">]</span>
    </a>
  )
}

<style>
  a.logo {
    color: inherit;
    text-decoration: none;
  }
</style>
