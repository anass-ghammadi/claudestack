---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — stats from siteConfig.stats with optional override
import { siteConfig } from '../config/site';

interface Stat {
  label: string;
  num: string;
  delta: string;
}

interface Props {
  header?: string;
  stats?: Stat[];
}

const {
  header = siteConfig.stats.label,
  stats = [...siteConfig.stats.items],
} = Astro.props;
---

{stats.length > 0 && (
  <section class="stats">
    <div class="container">
      <div class="stats-header">{header}</div>
      <div class="stats-grid">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-label">{s.label}</div>
            <div class="stat-num">{s.num}</div>
            <div class="stat-delta">{s.delta}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
