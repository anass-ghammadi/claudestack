---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — footer columns from siteConfig.footer.columns
import Logo from './Logo.astro';
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
const brand = siteConfig.name.toLowerCase();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand-col">
        <Logo variant="footer" />
        <p class="footer-desc">{siteConfig.description}</p>
      </div>
      {siteConfig.footer.columns.map((col) => (
        <div class="footer-col">
          <h3>{col.title.toLowerCase()}</h3>
          <ul>
            {col.links.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="footer-bottom">
      <div class="left">
        <span>© {year} [{brand}]</span>
        <span>{siteConfig.version}</span>
      </div>
      <span>built with care</span>
    </div>
  </div>
</footer>
