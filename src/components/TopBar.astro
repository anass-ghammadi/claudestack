---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — reads metrics from siteConfig
import { siteConfig } from '../config/site';

const essaysCount = siteConfig.stats.items.find((s) => s.label === 'essays')?.num;
const subsCount = siteConfig.newsletter.subscriberCount;
---

<div class="topbar">
  <div class="container topbar-inner">
    <div class="topbar-left">
      <span class="topbar-status">
        <span class="topbar-status-dot"></span>
        ONLINE
      </span>
      <span class="hide-mobile">{siteConfig.version}</span>
    </div>
    <div class="topbar-right">
      {essaysCount && <span class="hide-mobile">{essaysCount} ESSAYS</span>}
      {subsCount && <span>{subsCount} SUBS</span>}
    </div>
  </div>
</div>
