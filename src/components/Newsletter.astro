---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — provider-agnostic newsletter
import { siteConfig } from '../config/site';

const { enabled, provider, formId, headline, subtext, subscriberCount } = siteConfig.newsletter;

let action = '#';
let popupHref = '#';
let isWired = false;

if (enabled && formId) {
  if (provider === 'buttondown') {
    action = `https://buttondown.com/api/emails/embed-subscribe/${formId}`;
    popupHref = `https://buttondown.com/${formId}`;
    isWired = true;
  } else if (provider === 'convertkit') {
    action = `https://app.convertkit.com/forms/${formId}/subscriptions`;
    isWired = true;
  } else if (provider === 'emailoctopus') {
    action = `https://emailoctopus.com/lists/${formId}/members/embedded/1.3/add`;
    isWired = true;
  }
}
---

{enabled && (
  <section class="newsletter" id="newsletter">
    <div class="container">
      <div class="newsletter-block">
        <div>
          <div class="newsletter-meta">SUBSCRIBE / WEEKLY DIGEST</div>
          <h2>{headline}</h2>
          <p>{subtext}</p>
        </div>
        <form
          class="newsletter-form"
          action={action}
          method="post"
          target="popupwindow"
          onsubmit={isWired && provider === 'buttondown' ? `window.open('${popupHref}', 'popupwindow')` : undefined}
          aria-label="Newsletter signup"
        >
          <div class="newsletter-input-row">
            <label class="sr-only" for="newsletter-email">Email</label>
            <input
              id="newsletter-email"
              type="email"
              name="email"
              placeholder={isWired ? 'you@example.com' : 'newsletter coming soon'}
              required={isWired}
              disabled={!isWired}
              autocomplete="email"
            />
            {provider === 'buttondown' && <input type="hidden" name="embed" value="1" />}
            <button type="submit" disabled={!isWired}>SUBSCRIBE</button>
          </div>
          <div class="newsletter-sub-meta">
            {isWired ? (
              <>
                {subscriberCount && <span>{subscriberCount} subscribed</span>}
                <span>1-click unsubscribe</span>
              </>
            ) : (
              <span>configure newsletter in src/config/site.ts to enable</span>
            )}
          </div>
        </form>
      </div>
    </div>
  </section>
)}

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .newsletter-form input:disabled,
  .newsletter-form button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
