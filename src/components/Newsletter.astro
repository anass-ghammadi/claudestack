---
import { siteConfig } from '../lib/site-config';

const username = siteConfig.buttondownUsername;
const enabled = username.length > 0;
const action = enabled ? `https://buttondown.com/api/emails/embed-subscribe/${username}` : '#';
---

<section class="newsletter" id="newsletter">
  <div class="container">
    <div class="newsletter-block">
      <div>
        <div class="newsletter-meta">SUBSCRIBE / WEEKLY DIGEST</div>
        <h2>One letter,<br />every <span class="accent">Sunday</span>.</h2>
        <p>
          The week's most useful patterns and field notes from building with Claude Code. No fluff. Just signal.
        </p>
      </div>
      <form
        class="newsletter-form"
        action={action}
        method="post"
        target="popupwindow"
        onsubmit={enabled ? `window.open('https://buttondown.com/${username}', 'popupwindow')` : 'return false'}
        aria-label="Newsletter signup"
      >
        <div class="newsletter-input-row">
          <label class="sr-only" for="newsletter-email">Email</label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            placeholder={enabled ? 'you@example.com' : 'newsletter coming soon'}
            required={enabled}
            disabled={!enabled}
            autocomplete="email"
          />
          <input type="hidden" name="embed" value="1" />
          <button type="submit" disabled={!enabled}>SUBSCRIBE</button>
        </div>
        <div class="newsletter-sub-meta">
          {enabled ? (
            <>
              <span>{siteConfig.stats.subs} subscribed</span>
              <span>1-click unsubscribe</span>
            </>
          ) : (
            <span>add buttondown username in src/lib/site-config.ts to enable</span>
          )}
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .newsletter-form input:disabled,
  .newsletter-form button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
