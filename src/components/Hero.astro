---
// SPEC: BRIEF_CLAUDESTACK_PRODUCT.md#1.1 — hero copy from siteConfig.hero
import Terminal from './Terminal.astro';
import { siteConfig } from '../config/site';

const h = siteConfig.hero;
---

<section class="hero">
  <div class="container hero-inner">
    <div>
      <div class="hero-tag">
        <span class="hero-tag-dot"></span>
        {h.tag}
      </div>
      <h1>
        <span class="small">{h.titleSmall}</span>
        {h.titleLine1} <span class="accent">{h.titleAccent}</span><br />
        {h.titleLine2}<br />
        <span class="hero-bracket">&lt;</span>{h.titleTech}<span class="hero-bracket">/&gt;</span>
      </h1>
      <p class="hero-subtitle" set:html={h.subtitle}></p>
      <div class="hero-actions">
        <a href={h.ctaPrimary.href} class="btn-primary">{h.ctaPrimary.label}</a>
        <a href={h.ctaSecondary.href} class="btn-secondary">{h.ctaSecondary.label}</a>
      </div>
    </div>

    <Terminal variant="hero" title={h.terminalTitle} status={h.terminalStatus}>
      <div class="terminal-line"><span class="terminal-prompt">$</span> claude --session spec</div>
      <div class="terminal-line terminal-output">→ spec.session.active</div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> claude --session dev</div>
      <div class="terminal-line terminal-output">→ dev.session.active</div>
      <div class="terminal-line">&nbsp;</div>
      <div class="terminal-line terminal-comment"># routes tasks</div>
      <div class="terminal-line"><span class="terminal-keyword">def</span> <span class="terminal-success">route</span>(task):</div>
      <div class="terminal-line">&nbsp;&nbsp;spec = Spec.<span class="terminal-arg">draft</span>(task)</div>
      <div class="terminal-line">&nbsp;&nbsp;code = Dev.<span class="terminal-arg">build</span>(spec)</div>
      <div class="terminal-line">&nbsp;&nbsp;<span class="terminal-keyword">return</span> Audit.<span class="terminal-arg">review</span>(code)</div>
      <div class="terminal-line">&nbsp;</div>
      <div class="terminal-line"><span class="terminal-prompt">$</span> route(task)<span class="terminal-cursor"></span></div>
    </Terminal>
  </div>
</section>
