---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <div class="toc-label">contents</div>
    <ol>
      {items.map((h) => (
        <li class={h.depth === 3 ? 'toc-h3' : ''}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}
